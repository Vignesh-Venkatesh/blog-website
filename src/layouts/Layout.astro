---
import "../styles/global.css";
interface Props {
    title: string;
    description?: string;
}
const { title, description = "Blog | Vignesh Venkatesh" } = Astro.props;
---

<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <title>{title}</title>
    </head>
    <body class="bg-(--bg-deep-bg) text-primary">
        <slot />
    </body>
</html>
