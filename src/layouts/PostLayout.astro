---
import Layout from "./Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

interface Props {
    title: string;
    description: string;
    pubDate: Date;
    tags: string[];
    prevPost?: { slug: string; title: string } | null;
    nextPost?: { slug: string; title: string } | null;
    readingTime: string;
}

const { title, description, pubDate, tags, prevPost, nextPost, readingTime } =
    Astro.props;

const date = pubDate.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "2-digit",
});
---

<Layout title={`${title} — Blog | Vignesh Venkatesh`} description={description}>
    <Navbar />
    <main class="mx-auto py-14">
        <header class="mb-10 border-b border-border pb-8">
            <div class="flex gap-4 text-muted text-xs mb-3">
                <span>{date}</span>
                <span>·</span>
                <span>{readingTime}</span>
            </div>
            <h1 class="text-heading text-3xl font-bold mt-2 mb-4">{title}</h1>
            <p class="text-muted text-sm leading-relaxed mb-4">
                {description}
            </p>
            <div class="flex gap-2 flex-wrap">
                {
                    tags.map((tag) => {
                        const href = `/tags/${tag}`;
                        return (
                            <a
                                href={href}
                                class="border border-border text-muted text-xs px-2 py-0.5 hover:border-heading hover:text-heading transition-colors"
                            >
                                #{tag}
                            </a>
                        );
                    })
                }
            </div>
        </header>

        <article class="prose">
            <slot />
        </article>

        <nav
            class="flex justify-between items-start mt-16 pt-8 border-t border-border gap-4"
        >
            <div>
                {
                    prevPost && (
                        <a
                            href={`/blog/${prevPost.slug}`}
                            class="group flex flex-col"
                        >
                            <span class="text-muted text-xs mb-1">
                                ← previous
                            </span>
                            <span class="text-heading text-sm group-hover:opacity-80 transition-opacity">
                                {prevPost.title}
                            </span>
                        </a>
                    )
                }
            </div>
            <div class="text-right">
                {
                    nextPost && (
                        <a
                            href={`/blog/${nextPost.slug}`}
                            class="group flex flex-col items-end"
                        >
                            <span class="text-muted text-xs mb-1">next →</span>
                            <span class="text-heading text-sm group-hover:opacity-80 transition-opacity">
                                {nextPost.title}
                            </span>
                        </a>
                    )
                }
            </div>
        </nav>
    </main>
    <Footer />
</Layout>

<style>
    .prose {
        color: #ffd6a7;
        font-size: 0.9rem;
        line-height: 1.8;
    }
    .prose :global(h1) {
        color: #01df72;
        font-size: 2.125rem;
        font-weight: 600;
        margin: 2rem 0 0.75rem;
    }
    .prose :global(h2) {
        color: #01df72;
        font-size: 1.875rem;
        font-weight: 600;
        margin: 2rem 0 0.75rem;
    }
    .prose :global(h3) {
        color: #01df72;
        font-size: 1.5rem;
        font-weight: 600;
        margin: 1.5rem 0 0.5rem;
    }
    .prose :global(h4) {
        color: #01df72;
        font-size: 1.25rem;
        font-weight: 600;
        margin: 1.5rem 0 0.5rem;
    }
    .prose :global(h5) {
        color: #01df72;
        font-size: 1.125rem;
        font-weight: 600;
        margin: 1.5rem 0 0.5rem;
    }
    .prose :global(h6) {
        color: #01df72;
        font-size: 1rem;
        font-weight: 600;
        margin: 1.5rem 0 0.5rem;
    }
    .prose :global(p) {
        margin-bottom: 0.5rem;
    }
    .prose :global(a) {
        color: #01df72;
        border-bottom: 1px solid #0a3040;
        transition: border-color 0.2s;
    }
    .prose :global(a:hover) {
        border-color: #01df72;
    }
    .prose :global(strong) {
        color: #ffd6a7;
        font-weight: 600;
    }
    .prose :global(ul) {
        padding-left: 1.5rem;
        margin-bottom: 1.25rem;
        list-style: disc;
    }
    .prose :global(ol) {
        padding-left: 1.5rem;
        margin-bottom: 1.25rem;
        list-style: decimal;
    }
    .prose :global(li) {
        margin-bottom: 0.35rem;
    }
    .prose :global(blockquote) {
        border-left: 2px solid #01df72;
        padding-left: 1rem;
        color: #7a9e95;
        margin: 1.5rem 0;
    }
    .prose :global(code:not(pre code)) {
        background: #0a3040;
        color: #01df72;
        padding: 2px 6px;
        border-radius: 3px;
        font-size: 0.82rem;
    }
    .prose :global(pre) {
        background: #001220 !important;
        border: 1px solid #0a3040;
        border-radius: 6px;
        padding: 1.25rem;
        overflow-x: auto;
        margin: 1.5rem 0;
    }
    .prose :global(pre code) {
        font-size: 0.82rem;
    }
    .prose :global(hr) {
        border-color: #0a3040;
        margin: 2rem 0;
    }
    .prose :global(table) {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 1.25rem;
        font-size: 0.85rem;
    }
    .prose :global(th) {
        color: #01df72;
        border-bottom: 1px solid #0a3040;
        padding: 0.5rem 0.75rem;
        text-align: left;
    }
    .prose :global(td) {
        border-bottom: 1px solid #0a3040;
        padding: 0.5rem 0.75rem;
    }
</style>
