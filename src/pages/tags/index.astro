---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import HatchDivider from "../../components/HatchDivider.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from "astro:content";
import { FaArrowLeft } from "react-icons/fa";

const posts = await getCollection("blog", (post) => !post.data.draft);

// tag frequency map
const tagMap = new Map<string, number>();

for (const post of posts) {
    for (const tag of post.data.tags) {
        tagMap.set(tag, (tagMap.get(tag) ?? 0) + 1);
    }
}

// converting to array
const tags = [...tagMap.entries()]
    .map(([tag, count]) => ({ tag, count }))
    .sort((a, b) => b.count - a.count);
---

<Layout title="Tags | Blog">
    <main class="flex-1 flex flex-col">
        <!-- navbar -->
        <div class="sticky top-0 backdrop-blur-md">
            <div class="max-w-3xl mx-auto">
                <Navbar />
            </div>
            <HatchDivider />
        </div>

        <div
            class="max-w-3xl mx-auto border-x border-x-separator/50 flex-1 w-full"
        >
            <div class="px-6 sm:px-8 pt-10 pb-6 space-y-4">
                <a
                    href="/"
                    class="inline-flex items-center gap-2 font-google text-xs text-tertiary hover:text-green transition-colors group"
                >
                    <div
                        class="flex items-center gap-2 group-hover:gap-1 transition-all duration-200"
                    >
                        <FaArrowLeft size={10} />
                        <p>all posts</p>
                    </div>
                </a>
                <div>
                    <h1 class="text-3xl font-bold text-secondary">tags</h1>
                    <p class="text-sm text-tertiary mt-2">
                        {tags.length} total tags
                    </p>
                </div>
            </div>

            <HatchDivider />

            <div class="px-6 sm:px-8 py-8 flex flex-wrap gap-3">
                {
                    tags.map(({ tag, count }) => (
                        <a
                            href={`/tags/${tag}`}
                            class="group flex gap-3 items-baseline text-sm px-2 py-1 text-button-text rounded bg-button hover:text-green transition-colors duration-200"
                        >
                            <span>#{tag}</span>
                            <span class="text-xs font-bold text-tertiary group-hover:text-green">
                                {count}
                            </span>
                        </a>
                    ))
                }
            </div>

            <HatchDivider />
            <Footer />
            <HatchDivider />
        </div>
    </main>
</Layout>
