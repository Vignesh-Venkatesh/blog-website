---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import HatchDivider from "../../components/HatchDivider.astro";
import Footer from "../../components/Footer.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import { FaArrowLeft } from "react-icons/fa";

export async function getStaticPaths() {
    const posts = await getCollection("blog", (post) => !post.data.draft);

    const tags = [...new Set(posts.flatMap((post) => post.data.tags))];

    return tags.map((tag) => ({
        params: { tag },
    }));
}

const { tag } = Astro.params;

const posts = await getCollection(
    "blog",
    (post: CollectionEntry<"blog">) =>
        !post.data.draft && post.data.tags.includes(tag!),
);

const sortedPosts = posts.sort(
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const formatDate = (date: Date) =>
    new Intl.DateTimeFormat("en-US", {
        month: "short",
        day: "numeric",
        year: "numeric",
    }).format(date);
---

<Layout title={`#${tag} | blog.vigiii`}>
    <main class="flex-1 flex flex-col">
        <!-- navbar -->
        <div class="sticky top-0 backdrop-blur-md">
            <div class="max-w-3xl mx-auto">
                <Navbar />
            </div>
            <HatchDivider />
        </div>

        <div
            class="max-w-3xl mx-auto border-x border-x-separator/50 flex-1 w-full"
        >
            <!-- header -->
            <div class="px-6 sm:px-8 pt-10 pb-6 space-y-4">
                <a
                    href="/"
                    class="inline-flex items-center gap-2 font-google text-xs text-tertiary hover:text-green transition-colors group"
                >
                    <div
                        class="flex items-center gap-2 group-hover:gap-1 transition-all duration-200"
                    >
                        <FaArrowLeft size={10} />
                        <p>all posts</p>
                    </div>
                </a>
                <div>
                    <h1 class="text-3xl font-bold text-secondary">
                        #{tag}
                    </h1>
                    <p class="text-sm text-tertiary mt-2">
                        {sortedPosts.length} post(s)
                    </p>
                </div>
            </div>

            <HatchDivider />

            <!-- posts -->
            {
                sortedPosts.map((post, i) => (
                    <>
                        {i !== 0 && <HatchDivider />}
                        <a
                            href={`/blog/${post.id}`}
                            class="block py-6 hover:opacity-75 transition-opacity duration-200 px-6 sm:px-8"
                        >
                            <div class="flex justify-between items-baseline gap-4 mb-3">
                                <p class="text-xl font-bold text-secondary">
                                    {post.data.title}
                                </p>
                                <p class="text-sm text-tertiary whitespace-nowrap shrink-0">
                                    {formatDate(post.data.pubDate)}
                                </p>
                            </div>
                            <p class="text-sm mb-4 leading-relaxed">
                                {post.data.description}
                            </p>
                            <div class="flex flex-wrap gap-2">
                                {post.data.tags.map((tag: string) => (
                                    <span
                                        class="text-xs px-2 py-1 text-button-text rounded bg-button hover:text-green transition-colors duration-200"
                                        onclick={`event.preventDefault(); window.location='/tags/${tag}'`}
                                    >
                                        #{tag}
                                    </span>
                                ))}
                            </div>
                        </a>
                    </>
                ))
            }

            <HatchDivider />
            <Footer />
            <HatchDivider />
        </div>
    </main>
</Layout>
