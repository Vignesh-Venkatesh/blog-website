---
import Layout from "../layouts/Layout.astro";
import HatchDivider from "../components/HatchDivider.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { getCollection, type CollectionEntry } from "astro:content";

const posts: CollectionEntry<"blog">[] = await getCollection(
    "blog",
    (post: CollectionEntry<"blog">) => !post.data.draft,
);

const sortedPosts = posts.sort(
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const formatDate = (date: Date) =>
    new Intl.DateTimeFormat("en-US", {
        month: "short",
        day: "numeric",
        year: "numeric",
    }).format(date);
---

<Layout title="Blog | Vignesh Venkatesh">
    <main class="flex-1 flex flex-col">
        <!-- navbar -->
        <div class="sticky top-0 backdrop-blur-md">
            <div class="max-w-3xl mx-auto">
                <Navbar />
            </div>
            <HatchDivider />
        </div>

        <div
            class="max-w-3xl mx-auto border-x border-x-separator/50 flex-1 flex flex-col w-full"
        >
            <h1
                class="text-3xl font-bold pt-10 pb-5 text-secondary px-6 sm:px-8"
            >
                all_posts
            </h1>

            <HatchDivider />

            <div>
                {
                    sortedPosts.map((post, i) => (
                        <>
                            {i !== 0 && <HatchDivider />}
                            <a
                                href={`/blog/${post.id}`}
                                class="block py-6 opacity-75 hover:opacity-100 transition-all border-l-2 border-transparent hover:border-l-green duration-200 px-6 sm:px-8"
                            >
                                <div class="flex justify-between items-baseline gap-4 mb-3">
                                    <p class="text-xl font-bold text-secondary">
                                        {post.data.title}
                                    </p>
                                    <p class="text-sm text-tertiary whitespace-nowrap shrink-0">
                                        {formatDate(post.data.pubDate)}
                                    </p>
                                </div>
                                <p class="text-sm mb-4 leading-relaxed">
                                    {post.data.description}
                                </p>
                                <div class="flex flex-wrap gap-2">
                                    {post.data.tags.map((tag: string) => (
                                        <span
                                            class="text-xs px-2 py-1 text-button-text rounded bg-button hover:text-green transition-colors duration-200"
                                            onclick={`event.preventDefault(); window.location='/tags/${tag}'`}
                                        >
                                            #{tag}
                                        </span>
                                    ))}
                                </div>
                            </a>
                        </>
                    ))
                }
            </div>

            <HatchDivider />
            <Footer />
            <HatchDivider />
        </div>
    </main>
</Layout>
