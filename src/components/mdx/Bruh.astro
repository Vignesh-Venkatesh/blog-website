---
interface Props {
    text: string;
}
const { text } = Astro.props;
---

<div
    class="cry-wrapper rounded group relative isolate flex items-center bg-yellow-100/5 pl-11 pr-3 py-2 overflow-visible transition-colors duration-300 my-4"
>
    <div
        class="pointer-events-none absolute -left-4 top-1/2 -translate-y-1/2 w-16 h-16 bg-yellow-800/10 blur-xl"
    >
    </div>

    <div
        class="absolute -left-2.5 top-3/4 translate-y-[-12%] w-10 h-10 z-10 animate-[crybob_2.5s_ease-in-out_infinite]"
    >
        <svg viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg">
            <svg
                version="1.1"
                id="Layer_1"
                xmlns="http://www.w3.org/2000/svg"
                xmlns:xlink="http://www.w3.org/1999/xlink"
                viewBox="0 0 512.001 512.001"
                xml:space="preserve"
                fill="#000000"
                ><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g
                    id="SVGRepo_tracerCarrier"
                    stroke-linecap="round"
                    stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier">
                    <circle
                        style="fill:#F7B239;"
                        cx="256.004"
                        cy="256.004"
                        r="246.855"></circle>
                    <g>
                        <path
                            style="fill:#E09B2D;"
                            d="M126.306,385.694c-88.801-88.802-95.798-228.426-20.998-325.241 c-8.286,6.401-16.258,13.399-23.858,20.999c-96.401,96.401-96.401,252.698,0,349.099s252.698,96.401,349.099,0 c7.599-7.599,14.597-15.573,20.999-23.858C354.733,481.492,215.108,474.495,126.306,385.694z"
                        ></path>
                        <path
                            style="fill:#E09B2D;"
                            d="M297.481,349.115h-85.403c-5.054,0-9.15-4.097-9.15-9.15s4.095-9.15,9.15-9.15h85.403 c5.054,0,9.15,4.097,9.15,9.15S302.534,349.115,297.481,349.115z"
                        ></path>
                    </g>
                    <path
                        d="M256.001,0C114.841,0,0,114.841,0,256.001s114.841,256.001,256.001,256.001S512.001,397.16,512.001,256.001 S397.16,0,256.001,0z M256.001,493.701c-131.069,0-237.702-106.631-237.702-237.7S124.932,18.299,256.001,18.299 s237.702,106.632,237.702,237.702S387.068,493.701,256.001,493.701z"
                    ></path>
                    <path
                        d="M371.284,296.658H138.275c-5.054,0-9.15,4.097-9.15,9.15s4.095,9.15,9.15,9.15h233.008c5.054,0,9.15-4.097,9.15-9.15 C380.433,300.754,376.337,296.658,371.284,296.658z"
                    ></path>
                    <path
                        d="M180.577,226.834c0-18.666-15.186-33.852-33.852-33.852s-33.852,15.186-33.852,33.852s15.186,33.852,33.852,33.852 S180.577,245.501,180.577,226.834z"
                    ></path>
                    <path
                        d="M365.275,192.982c-18.666,0-33.852,15.186-33.852,33.852s15.186,33.852,33.852,33.852s33.852-15.186,33.852-33.852 S383.942,192.982,365.275,192.982z"
                    ></path>
                    <g>
                        <circle
                            style="fill:#FFFFFF;"
                            cx="155.969"
                            cy="219.735"
                            r="9.15"></circle>
                        <circle
                            style="fill:#FFFFFF;"
                            cx="374.338"
                            cy="219.735"
                            r="9.15"></circle>
                    </g>
                </g></svg
            >
        </svg>
    </div>

    <div class="relative z-10 flex flex-col">
        <span class="text-secondary font-google text-xs"><slot /></span>
    </div>
</div>

<style>
    @keyframes crybob {
        0%,
        100% {
            transform: translateY(-60%) rotate(-12deg);
        }
        50% {
            transform: translateY(-68%) rotate(-15deg);
        }
    }
</style>
