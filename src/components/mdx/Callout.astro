const svgList = svgs[variant];
---

<div
    class={`font-google rounded pl-11 pr-3 py-2 my-3 overflow-visible group transition-all duration-300 relative ${style.cardBg}`}
>
    <!-- glow effect -->
    <div
        class={`pointer-events-none absolute -left-4 top-1/2 -translate-y-1/2 w-16 h-16 blur-xl ${style.glow}`}
    >
    </div>

    <!-- svgs -->
    {svgList.map((svg) => <div class={svg.class} set:html={svg.markup} />)}

    <!-- content -->
    <div class="relative z-10 flex flex-col">
        {
            variant === "tip" && (
                <span class="text-green/80 font-bold text-xs uppercase">
                    tip
                </span>
            )
        }
        {
            variant === "warning" && (
                <span class="text-yellow-500/80 font-bold text-xs uppercase">
                    warning
                </span>
            )
        }
        {
            variant === "question" && (
                <span class="text-red-500/80 font-bold text-xs uppercase">
                    question
                </span>
            )
        }
        <span class={style.span}><slot /></span>
    </div>
</div>

<style>
    @keyframes bob {
        0%,
        100% {
            transform: translateY(-60%) rotate(-12deg);
        }
        50% {
            transform: translateY(-68%) rotate(-15deg);
        }
    }
</style>
