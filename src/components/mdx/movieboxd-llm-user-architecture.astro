---
import { FaArrowDownLong } from "react-icons/fa6";
---

<div class="my-4">
    <div class="font-google flex flex-col items-center">
        <div class="flex flex-col items-center p-2 rounded">
            <!-- config -->
            <div
                class="bg-card flex flex-col items-center border border-tertiary/30 rounded p-2"
            >
                <span class="font-bold text-yellow-500">config</span>
                <p class="text-xs">.env, users.json, seed_movies.json</p>
            </div>

            <FaArrowDownLong className="text-tertiary my-2" />

            <!-- seed -->
            <div
                class="bg-card flex flex-col items-center border border-tertiary/30 rounded p-2"
            >
                <span class="font-bold text-green-500">seed</span>
                <p class="text-xs">orchestrator, decision tree, user loop</p>
            </div>

            <div class="w-0.5 h-4 bg-tertiary mt-2"></div>
            <div class="w-[67%] h-0.5 bg-tertiary rounded"></div>

            <div class="flex justify-around w-full">
                <FaArrowDownLong className="text-tertiary mb-2" />
                <FaArrowDownLong className="text-tertiary mb-2" />
                <FaArrowDownLong className="text-tertiary mb-2" />
            </div>

            <div class="flex gap-3 1fr">
                <div class="flex-1 flex flex-col items-center">
                    <!-- client -->
                    <div
                        class="bg-card flex flex-col items-center justify-center border border-tertiary/30 rounded p-2 w-full"
                    >
                        <span class="font-bold text-purple-400">client</span>
                        <p class="text-xs text-center">Auth, GET, POST</p>
                    </div>

                    <FaArrowDownLong className="text-tertiary my-2" />

                    <!-- actions -->
                    <div
                        class="bg-card flex flex-col items-center justify-center border border-tertiary/30 rounded p-2 w-full"
                    >
                        <span class="font-bold text-orange-400">actions</span>
                        <p class="text-xs text-center">
                            watched, favorited, watchlisted, review
                        </p>
                    </div>
                </div>

                <!-- movie -->
                <div
                    class="bg-card flex flex-col items-center justify-center border border-tertiary/30 rounded p-2 flex-1"
                >
                    <span class="font-bold text-blue-400">movie</span>
                    <p class="text-xs text-center">
                        pick movie from seed list, fetching movie info
                    </p>
                </div>

                <!-- llm -->
                <div
                    class="bg-card flex flex-col items-center justify-center border border-tertiary/30 rounded p-2 flex-1"
                >
                    <span class="font-bold text-red-400">llm</span>
                    <p class="text-xs">stream review from Ollama</p>
                </div>
            </div>
        </div>

        <div class="self-start w-1/3 flex justify-center">
            <FaArrowDownLong className="text-tertiary my-2" />
        </div>

        <div class="p-2 rounded w-full">
            <!-- MovieBoxd -->
            <div
                class="self-start bg-card flex flex-col items-center border border-tertiary/30 rounded p-2"
            >
                <span class="font-bold text-fuchsia-300">MovieBoxd API</span>
            </div>
        </div>
    </div>

    <div class="flex justify-end mt-2">
        <span class="text-xs italic text-tertiary/50">
            Inspired by
            <a
                href="https://support.claude.com/en/articles/9487310-what-are-artifacts-and-how-do-i-use-them"
                target="_blank"
            >
                Claude's Artifacts
            </a>
        </span>
    </div>
</div>
